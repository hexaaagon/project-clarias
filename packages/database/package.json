{
  "name": "@project-clarias/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./slack": "./src/slack.ts",
    "./migrate": "./src/migrate.ts",
    "./drizzle.config": "./drizzle.config.ts",
    "./supabase/*": "./src/supabase/*.ts",
    "./schema/*": "./src/schema/*.ts",
    "./types/*": "./src/types/*.ts"
  },
  "scripts": {
    "generate": "bun --env-file=../../.env run generate:auth && bun --env-file=../../.env run generate:migrations",
    "generate:auth": "bunx @better-auth/cli generate --config ../auth/src/index.ts --output ./src/schema/auth.ts -y",
    "generate:migrations": "bun drizzle-kit generate",
    "generate:types": "supabase gen types typescript --project-id \"dhadwsjyljonlqgaytzr\" --schema public > ../shared/types/database.ts",
    "migrate": "bun --env-file=../../.env src/migrate.ts",
    "seed": "bun --env-file=../../.env src/seed.ts",
    "drizzle-kit": "bun --env-file=../../.env drizzle-kit-w-env",
    "drizzle-kit-w-env": "drizzle-kit",
    "drop": "bun drizzle-kit drop",
    "pull": "bun drizzle-kit introspect",
    "push": "bun drizzle-kit push",
    "studio": "bun drizzle-kit studio",
    "check": "bun drizzle-kit check",
    "postinstall": "bun ./src/postinstall.ts"
  },
  "dependencies": {
    "@project-clarias/env": "*",
    "@project-clarias/shared": "*",
    "@project-clarias/util": "*",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "next": "^16.2.9",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/fs-extra": "^11.0.4",
    "drizzle-kit": "^0.31.10",
    "supabase": "^2.106.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
